{
	"custom/distro": {
		"format": "  ",
		"tooltip": false,
		"on-click": "~/.config/rofi/powermenu/type-2/powermenu.sh"
	},
	"hyprland/window": {
    "format": "{}",
		// "max-length": 30,
    "rewrite": {
				"(.*) - YouTube.*": "  - $1",
				"(.*) - Brave": "$1",
				"(.*) - (.*) - Deezer.*": "  - $1",
				"nvim (.*)": " $1",
				// "^~(.*)": " $1"
				"": "Empty Workspace"
    },
    "separate-outputs": true
	}
}
